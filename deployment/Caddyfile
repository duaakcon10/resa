:80 {
	encode gzip

	# WebSocket bots — explicit path (Caddy auto-upgrades WS)
	handle /ws/* {
		reverse_proxy api:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}

	handle /api/* {
		reverse_proxy api:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}

	handle /health {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy api:8000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto https
		}
	}

	header {
		X-Content-Type-Options nosniff
		-Server
	}
}
